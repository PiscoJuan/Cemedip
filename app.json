{
  "expo": {
    "name": "Cemedip",
    "slug": "Cemedip",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Recurso 4.png",
    "splash": {
      "image": "./assets/images/Recurso 3v2.png",
      "resizeMode": "contain",
      "backgroundColor": "#9C489E"
    },
    "scheme": "cemedip",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hangaroa.cemedip",
      "buildNumber": "1"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.hangaroa.cemedip",
      "versionCode": 1
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Recurso 3v2.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#9C489E"
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
